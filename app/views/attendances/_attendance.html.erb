<div id="<%= dom_id attendance %>" class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-sm font-semibold text-slate-900">
        <%= attendance.employee&.name || "Employee ##{attendance.employee_id}" %>
      </p>
      <p class="mt-0.5 text-xs text-slate-500">
        วันที่ <%= attendance.check_in&.to_date %>
      </p>
    </div>
    <div class="text-right text-xs">
      <p class="text-slate-500">ชั่วโมงทำงาน</p>
      <p class="font-mono text-sm font-semibold text-slate-900">
        <%= number_with_precision(attendance.working_hours, precision: 3) %> h
      </p>
      <% if attendance.ot_hours.positive? %>
        <p class="mt-1 font-mono text-xs font-semibold text-emerald-700">
          OT <%= number_with_precision(attendance.ot_hours, precision: 3) %> h
        </p>
      <% else %>
        <p class="mt-1 text-xs text-slate-400">
          ไม่มี OT
        </p>
      <% end %>
    </div>
  </div>

  <dl class="mt-4 grid grid-cols-2 gap-4 text-xs">
    <div>
      <dt class="text-slate-500">Check in</dt>
      <dd class="mt-1 font-mono text-slate-900">
        <%= attendance.check_in&.strftime("%Y-%m-%d %H:%M") %>
      </dd>
    </div>
    <div>
      <dt class="text-slate-500">Check out</dt>
      <dd class="mt-1 font-mono text-slate-900">
        <%= attendance.check_out&.strftime("%Y-%m-%d %H:%M") %>
      </dd>
    </div>
  </dl>
</div>
