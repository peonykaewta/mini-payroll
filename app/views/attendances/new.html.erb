<% content_for :title, "New attendance" %>

<div class="space-y-6">
  <div class="flex items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-slate-900">
        New attendance
      </h1>
      <p class="mt-1 text-sm text-slate-500">
        บันทึกเวลาเข้างาน–ออกงานให้พนักงาน 1 คนใน 1 วัน
      </p>
    </div>

    <%= link_to "Back to list",
                attendances_path,
                class: "inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 shadow-sm transition hover:bg-slate-50" %>
  </div>

  <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <%= render "form", attendance: @attendance %>
  </div>
</div>
