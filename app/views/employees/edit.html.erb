<% content_for :title, "Editing employee" %>

<div class="space-y-6">
  <div class="flex items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-slate-900">
        Editing employee
      </h1>
      <p class="mt-1 text-sm text-slate-500">
        แก้ไขข้อมูลพนักงาน: <span class="font-medium text-slate-800"><%= @employee.name %></span>
      </p>
    </div>

    <div class="flex flex-wrap gap-2">
      <%= link_to "Show",
                  @employee,
                  class: "inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 shadow-sm transition hover:bg-slate-50" %>

      <%= link_to "Back to employees",
                  employees_path,
                  class: "inline-flex items-center justify-center rounded-md px-3 py-1.5 text-sm font-medium text-slate-600 hover:text-slate-900" %>
    </div>
  </div>

  <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <%= render "form", employee: @employee %>
  </div>
</div>
