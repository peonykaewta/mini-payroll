<% content_for :title, "Employees" %>

<div class="space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-slate-900">
        Employees
      </h1>
      <p class="mt-1 text-sm text-slate-500">
        รายชื่อพนักงานทั้งหมดในระบบ Mini Payroll
      </p>
    </div>

    <div class="flex flex-wrap gap-2">
      <%= link_to "New employee",
                  new_employee_path,
                  class: "inline-flex items-center justify-center rounded-md bg-slate-900 px-3 py-1.5 text-sm font-medium text-white shadow-sm transition hover:bg-slate-800" %>
    </div>
  </div>

  <div id="employees" class="grid gap-4 md:grid-cols-2">
    <% @employees.each do |employee| %>
      <div class="group relative overflow-hidden rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-md">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-sm font-semibold text-slate-900">
              <%= employee.name %>
            </p>
            <p class="mt-0.5 text-xs text-slate-500">
              <%= employee.position.presence || "ไม่ระบุตำแหน่ง" %>
            </p>
          </div>
          <div class="text-right">
            <p class="text-[11px] uppercase tracking-wide text-slate-400">
              Base salary
            </p>
            <p class="font-mono text-sm font-semibold text-slate-900">
              <%= number_to_currency(employee.base_salary, unit: "฿", precision: 2) %>
            </p>
          </div>
        </div>

        <div class="mt-4 flex items-center justify-between text-xs text-slate-500">
          <p>
            Working days:
            <span class="font-mono text-slate-800"><%= number_with_precision(employee.working_days, precision: 2) %></span>
          </p>
          <p>
            Net pay:
            <span class="font-mono font-semibold text-emerald-700"><%= number_to_currency(employee.net_pay, unit: "฿", precision: 2) %></span>
          </p>
        </div>

        <div class="mt-4 flex items-center justify-between text-xs">
          <%= link_to "View details",
                      employee,
                      class: "inline-flex items-center text-slate-700 hover:text-slate-900" %>

          <div class="flex items-center gap-2">
            <%= link_to "Edit",
                        edit_employee_path(employee),
                        class: "text-slate-500 hover:text-slate-800" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
